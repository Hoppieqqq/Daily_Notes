    "description":  "Obsidian plugin that opens today\u0027s daily note in a floating always-on-top window.",
    "main":  "main.js",
    "scripts":  {
                    "dev":  "node esbuild.config.mjs --watch",
                    "build":  "tsc --noEmit \u0026\u0026 node esbuild.config.mjs",
