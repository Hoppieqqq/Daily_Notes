{
  "name": "daily-floating-note",
  "version": "1.0.0",
  "description": "Obsidian plugin that opens today's daily note in a floating always-on-top window.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc --noEmit && node esbuild.config.mjs",
    "lint": "tsc --noEmit",
    "version": "node version-bump.mjs"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "daily-notes"
  ],
  "author": "Hoppieqqq",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hoppieqqq/Daily_Notes.git"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "esbuild": "^0.25.11",
    "obsidian": "^1.8.10",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
