{
    "name": "daily-floating-note",
    "version": "1.0.4",
    "description": "Obsidian plugin that opens today's daily note in a floating always-on-top window.",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs --watch",
        "build": "tsc --noEmit && node esbuild.config.mjs",
        "lint": "tsc --noEmit",
        "lint:review": "eslint src",
        "version": "node version-bump.mjs"
    },
    "keywords": [
        "obsidian",
        "obsidian-plugin",
        "daily-notes"
    ],
    "author": "Hoppieqqq",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Hoppieqqq/Daily_Notes.git"
    },
    "devDependencies": {
        "@eslint/js": "^8.57.1",
        "@types/node": "^24.9.1",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "esbuild": "^0.25.11",
        "eslint": "^8.57.1",
        "eslint-plugin-obsidian": "^2.30.0",
        "obsidian": "^1.8.10",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3"
    }
}
